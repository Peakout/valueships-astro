const DIM_DESC = {
  toolkit: {
    L: 'No clear ownership or dedicated team. Pricing decisions made on a whim, without structured tools or processes. Often relies on intuition or ad-hoc solutions.',
    M: 'Pricing function is developing. Basic tools, not fully optimized. Sometimes guided by data, but no full governance or alignment across departments.',
