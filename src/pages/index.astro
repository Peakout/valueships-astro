const ARCHETYPES = {
  LLL: {
    code: 'LLL',
    name: 'The Improvisers',
    cls: 'Class 1',
    leakLo: 0.17, leakHi: 0.25,
    profile: 'Pricing is reactive, deal-driven, and inconsistent. There is no real owner, no real process, and no real enforcement. Every deal is effectively a fresh negotiation, and the outcome depends more on the rep\'s judgment than on any commercial logic the company has built.',
    moves: [
      'Assign a single pricing owner, even part-time, so someone is accountable for pricing decisions and outcomes.',
