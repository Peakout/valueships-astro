  { label: 'Class 5', name: 'Masters',          lo: 0.03, hi: 0.08, highlight: false },
];

function formatEur(n) {
  if (n >= 1000000) return '€' + (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1000) return '€' + Math.round(n / 1000) + 'K';
  return '€' + Math.round(n);
}

function renderLeakage(arrM) {
  const arr = arrM * 1000000;
  const maxHi = LEAKAGE_CLASSES[0].hi * arr;
  const rows = document.getElementById('leakage-rows');
  rows.innerHTML = LEAKAGE_CLASSES.map(c => {
    const lo = Math.round(c.lo * arr);
    const hi = Math.round(c.hi * arr);
    const barW = Math.round((c.hi / LEAKAGE_CLASSES[0].hi) * 100);
    return `<div class="leakage-row${c.highlight ? ' leakage-row--highlight' : ''}">
      <div class="leakage-row__meta">
        <span class="leakage-row__label">${c.label} <em>${c.name}</em></span>
        <span class="leakage-row__amount">${formatEur(lo)}–${formatEur(hi)}/yr</span>
      </div>
      <div class="leakage-track"><div class="leakage-fill" style="width:${barW}%"></div></div>
    </div>`;
  }).join('');
}

document.getElementById('arr-picker').addEventListener('click', e => {
  const pill = e.target.closest('.arr-pill');
  if (!pill) return;
  document.querySelectorAll('.arr-pill').forEach(p => p.classList.remove('active'));
  pill.classList.add('active');
  renderLeakage(parseFloat(pill.dataset.arr));
});

renderLeakage(5);

/* =========================================================
   RESULT GATE MODAL
   ========================================================= */
document.getElementById('rg-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const email = document.getElementById('rg-email').value.trim();
  const errorEl = document.getElementById('rg-error');
  if (!email) { errorEl.textContent = 'Please enter your email.'; return; }
  if (!isBusinessEmail(email)) { errorEl.textContent = 'Please use your work email address.'; return; }
  errorEl.textContent = '';
  await submitToMake(email, 'result-modal');
  document.getElementById('rg-backdrop').classList.remove('active');
});

/* boot */
show('hero');
</script>

