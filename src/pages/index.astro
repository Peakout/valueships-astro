  },
  setting: {
    L: 'Reliance on basic strategies (cost-plus, competitor-based) with no deep understanding of customer value. Pricing set without clear strategy. Missed opportunities, underpricing.',
    M: 'Moving toward structured strategy with some value-based pricing and segmentation. Beginning to test models, but the approach is inconsistent and not fully optimized.',
    H: 'Robust, data-driven strategy based on customer value and market conditions. Regular price tests and experiments. Sophisticated models, continuously gathering insights.'
  },
  execution: {
    L: 'Sales teams disregard pricing guidelines. Unauthorized discounts and pricing structure deviations. Inconsistent price realization. Vulnerable to revenue loss and margin erosion.',
    M: 'Some controls in place, but occasional deviations. Reps generally adhere, but some deals slip through. Price realization is mostly good, not fully optimized.',
    H: 'Full control and adherence. Sales teams strictly follow guidelines, minimal discounting or deviation. Strong enforcement. Pricing decisions fully realized across channels.'
  }
};

/* =========================================================
   STATE
   ========================================================= */
const state = {
  current: 0,
  answers: new Array(QUESTIONS.length).fill(null)
};

/* =========================================================
   STAGE TRANSITIONS
   ========================================================= */
function show(stage) {
  document.getElementById('stage-hero').style.display = stage === 'hero' ? 'block' : 'none';
  document.getElementById('stage-quiz').classList.toggle('active', stage === 'quiz');
  document.getElementById('stage-result').classList.toggle('active', stage === 'result');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('start-quiz').addEventListener('click', () => {
  state.current = 0;
  state.answers.fill(null);
  renderQuestion();
  show('quiz');
});

document.getElementById('restart-btn').addEventListener('click', () => {
  show('hero');
});

/* =========================================================
   QUIZ RENDERING
   ========================================================= */
const host = document.getElementById('question-host');
const fill = document.getElementById('progress-fill');
const lbl  = document.getElementById('progress-label');
const next = document.getElementById('next-btn');
const back = document.getElementById('back-btn');

function renderQuestion() {
  const q = QUESTIONS[state.current];
  const i = state.current;
  fill.style.width = ((i + 1) / QUESTIONS.length * 100) + '%';
  lbl.textContent = `Question ${i + 1} of ${QUESTIONS.length}`;
  back.disabled = false;
  next.disabled = state.answers[i] === null;
  next.textContent = i === QUESTIONS.length - 1 ? 'Get my archetype →' : 'Next →';

  if (q.type === 'arr') {
    const v = state.answers[i] ?? 5;
    host.innerHTML = `
      <span class="question__dim">${q.short}</span>
      <h2 class="question__text">${q.text}</h2>
      <div class="arr-input">
        <div class="arr-input__row">
          <div class="arr-input__display" id="arr-display">€${v}M</div>
          <input type="range" min="1" max="100" step="1" value="${v}" id="arr-range">
        </div>
        <div class="arr-input__hint">Drag to adjust. Used only to estimate your annual revenue leakage in euros.</div>
      </div>
    `;
    const range = document.getElementById('arr-range');
    const disp  = document.getElementById('arr-display');
    state.answers[i] = parseInt(range.value, 10);
    next.disabled = false;
    range.addEventListener('input', e => {
      const val = parseInt(e.target.value, 10);
      disp.textContent = `€${val}M`;
      state.answers[i] = val;
    });
    return;
  }

  host.innerHTML = `
    <span class="question__dim">${q.short}</span>
    <h2 class="question__text">${q.text}</h2>
    <div class="answers" id="answers"></div>
  `;
  const wrap = document.getElementById('answers');
  q.options.forEach((opt, idx) => {
    const btn = document.createElement('button');
    btn.className = 'answer';
    btn.type = 'button';
    btn.dataset.value = idx + 1;
    btn.innerHTML = `<span class="answer__num">${idx + 1}</span><span class="answer__text">${opt}</span>`;
    if (state.answers[i] === idx + 1) btn.classList.add('selected');
    btn.addEventListener('click', () => selectAnswer(idx + 1));
    wrap.appendChild(btn);
  });
}

let advanceTimer = null;
function selectAnswer(value) {
  state.answers[state.current] = value;
  document.querySelectorAll('#answers .answer').forEach(el => {
    el.classList.toggle('selected', parseInt(el.dataset.value, 10) === value);
  });
  next.disabled = false;
  if (advanceTimer) clearTimeout(advanceTimer);
  advanceTimer = setTimeout(() => next.click(), 320);
}

next.addEventListener('click', () => {
  if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
  if (state.current === QUESTIONS.length - 1) {
    finish();
    return;
  }
  state.current++;
  renderQuestion();
});

back.addEventListener('click', () => {
  if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
  if (state.current === 0) { show('hero'); return; }
  state.current--;
  renderQuestion();
});

document.addEventListener('keydown', (e) => {
  if (!document.getElementById('stage-quiz').classList.contains('active')) return;
  const q = QUESTIONS[state.current];
  if (q.type === 'arr') return;
  const k = parseInt(e.key, 10);
  if (k >= 1 && k <= 5) selectAnswer(k);
  if (e.key === 'Enter' && !next.disabled) next.click();
  if (e.key === 'ArrowLeft' && !back.disabled) back.click();
});

/* =========================================================
   SCORING
   ========================================================= */
function bucket(avg) {
  if (avg >= 4.0) return 'H';
  if (avg >= 2.5) return 'M';
  return 'L';
}

function nearestArchetype(triple) {
  if (ARCHETYPES[triple]) return triple;
  let bestKey = 'MMM', bestDist = 99;
  Object.keys(ARCHETYPES).forEach(k => {
    let d = 0;
    for (let i = 0; i < 3; i++) if (k[i] !== triple[i]) d++;
    if (d < bestDist) { bestDist = d; bestKey = k; }
  });
  return bestKey;
}

function fmtEur(n) {
  if (n >= 1000000) return '€' + (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1000) return '€' + Math.round(n / 1000) + 'K';
  return '€' + n;
}

function finish() {
  const tk = (state.answers[0] + state.answers[1]) / 2;
  const st = (state.answers[2] + state.answers[3]) / 2;
  const ex = (state.answers[4] + state.answers[5]) / 2;
  const arr = state.answers[6] * 1_000_000; // millions to euros

  const triple = bucket(tk) + bucket(st) + bucket(ex);
  const matched = nearestArchetype(triple);
  const a = ARCHETYPES[matched];

  document.getElementById('r-code').textContent = a.code;
  document.getElementById('r-class').textContent = a.cls;
  document.getElementById('r-name').textContent = a.name;
  document.getElementById('r-profile').textContent = a.profile;

  const lo = Math.round(arr * a.leakLo);
  const hi = Math.round(arr * a.leakHi);
  document.getElementById('r-leakage').textContent = `${fmtEur(lo)} - ${fmtEur(hi)}`;
  document.getElementById('r-leakage-sub').textContent = `Based on €${state.answers[6]}M ARR and ${(a.leakLo * 100).toFixed(0)}-${(a.leakHi * 100).toFixed(0)}% MRR leakage typical of ${a.code} profiles.`;

  const setDim = (prefix, dim, val) => {
    const b = bucket(val);
    const score = document.getElementById(`r-${prefix}-score`);
    score.className = 'dim__score ' + b.toLowerCase();
    score.textContent = b === 'L' ? 'Low' : b === 'M' ? 'Medium' : 'High';
    document.getElementById(`r-${prefix}-desc`).textContent = DIM_DESC[dim][b];
  };
  setDim('tk', 'toolkit', tk);
  setDim('st', 'setting', st);
  setDim('ex', 'execution', ex);

  const movesEl = document.getElementById('r-moves');
  movesEl.innerHTML = '';
  a.moves.forEach((m, i) => {
    const li = document.createElement('li');
    li.innerHTML = `<span class="moves__num">${i + 1}</span><span class="moves__text">${m}</span>`;
    movesEl.appendChild(li);
  });

  document.getElementById('r-quote-text').textContent = '"' + a.quote.text + '"';
  document.getElementById('r-quote-author').innerHTML = `<strong>${a.quote.author}</strong> · ${a.quote.role}`;

  renderArchetypeGallery(matched);
  show('result');

  // Populate modal teaser
  document.getElementById('rg-code').textContent = a.code;
  document.getElementById('rg-name').textContent = a.name;
  document.getElementById('rg-desc').textContent = a.profile;
  document.getElementById('rg-backdrop').classList.add('active');
}

function renderArchetypeGallery(matched) {
  const wrap = document.getElementById('arch-gallery');
  wrap.innerHTML = '';
  ['LLL', 'MLL', 'MMM', 'MHH', 'HHH'].forEach(code => {
    const a = ARCHETYPES[code];
    const div = document.createElement('div');
    div.className = 'arch-card' + (code === matched ? ' you' : '');
    div.innerHTML = `
      <div class="arch-card__code">${code}</div>
      <div class="arch-card__name">${a.name}</div>
      <div class="arch-card__leak">Leakage <strong>${(a.leakLo * 100).toFixed(0)}-${(a.leakHi * 100).toFixed(0)}%</strong> · ${a.cls}${code === matched ? ' · YOU' : ''}</div>
    `;
    wrap.appendChild(div);
  });
}

