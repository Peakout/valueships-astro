      author: 'Sara McVeigh Archer',
      role: 'CRO, ChartMogul'
    }
  },
  MMM: {
    code: 'MMM',
    name: 'The Competent Operators',
    cls: 'Class 2 · Most common profile',
    leakLo: 0.10, leakHi: 0.18,
