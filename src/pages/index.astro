---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>State of European SaaS Pricing 2026 - Find your archetype</title>
<meta name="description" content="A 90-second diagnostic based on the survey of ~100 European SaaS C-suite leaders. Find your pricing archetype and see how much revenue you're leaving on the table.">
<meta name="robots" content="noindex, nofollow">
<link rel="icon" type="image/png" href={`${base}/favicon.png`}>
<link rel="stylesheet" href={`${base}/colors_and_type.css`}>
<style is:global>
  /* ============== layout shell ============== */
  html { scroll-behavior: smooth; }
  body { background: var(--surface-dim); }
  .wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: 32px 24px 96px;
  }
  .breadcrumb {
    font-size: 12px;
    color: var(--fg2);
    margin-bottom: 32px;
    letter-spacing: 0.3px;
  }
  .breadcrumb a { color: var(--fg2); }
  .breadcrumb a:hover { color: var(--primary); }
  .breadcrumb .sep { margin: 0 8px; color: var(--fg3); }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 500;
    color: var(--fg2);
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .pill__dot {
    width: 6px; height: 6px;
    background: var(--primary);
    border-radius: 50%;
  }

  /* ============== hero ============== */
  .hero {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-xl);
    padding: 64px 64px 56px;
    box-shadow: var(--elevation-1);
    margin-bottom: 24px;
    overflow: hidden;
  }
  /* Paper-airplane / sharp magenta triangle - brand signature motif */
  .hero__plane {
    position: absolute;
    top: -40px;
    right: -60px;
    width: 280px;
    height: 280px;
    pointer-events: none;
    opacity: 0.85;
  }
  .hero__plane svg { width: 100%; height: 100%; display: block; }
  .hero__inner { position: relative; z-index: 1; }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, var(--fs-headline-large));
    line-height: 1.05;
    letter-spacing: var(--ls-headline-large);
    font-weight: var(--fw-medium);
    margin: 16px 0 18px;
    max-width: 18ch;
    color: var(--fg1);
  }
  .hero h1 em {
    font-style: normal;
    color: var(--primary);
    font-weight: var(--fw-medium);
  }
  .hero__lede {
    font-family: var(--font-sans);
    font-size: var(--fs-body-large);
    line-height: 1.55;
    color: var(--fg2);
    font-weight: var(--fw-light);
    max-width: 60ch;
    margin-bottom: 32px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--outline-variant);
    border-bottom: 1px solid var(--outline-variant);
    margin: 32px 0;
  }
  .stat {
    padding: 24px 16px;
    border-right: 1px solid var(--outline-variant);
  }
  .stat:last-child { border-right: none; }
  .stat__num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-headline-medium);
    color: var(--primary);
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat__num.neutral { color: var(--fg1); }
  .stat__lbl {
    font-size: var(--fs-label-small);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--fg2);
    font-weight: var(--fw-medium);
  }

  /* ============== buttons ============== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-md);
    font-size: var(--fs-body-medium);
    font-weight: var(--fw-medium);
    cursor: pointer;
    border: 1px solid transparent;
    font-family: var(--font-sans);
    transition: background var(--motion-short) var(--motion-standard),
                color var(--motion-short) var(--motion-standard);
    box-sizing: border-box;
    max-width: 100%;
  }
  .btn-primary {
    background: #ff005e;
    color: #fff;
  }
  .btn-primary:hover { background: #cc004b; color: #fff; }
  .btn-primary:active { background: #a8003d; color: #fff; }
  .btn-secondary {
    background: transparent;
    color: var(--primary);
    border-color: var(--primary);
  }
  .btn-secondary:hover { background: var(--surface-pink-softest); }
  .btn-ghost {
    background: transparent;
    color: var(--fg1);
    border-color: var(--outline-variant);
  }
  .btn-ghost:hover { background: var(--surface-container); }
  .btn-large { padding: 16px 28px; font-size: 15px; }
  .btn-outline {
    background: transparent;
    color: #ff005e;
    border: 2px solid #ff005e;
  }
  .btn-outline:hover { background: #ff005e; color: #fff; }
  .btn-outline:active { background: #cc004b; color: #fff; }

  .hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  /* ============== krzysztof card ============== */
  .krzysztof-card {
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .krzysztof-card__photo {
    flex-shrink: 0;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--primary);
  }
  .krzysztof-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .krzysztof-card__body { flex: 1; }
  .krzysztof-card__kicker {
    font-size: 11px;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--primary);
    margin: 0 0 8px;
  }
  .krzysztof-card__name-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .krzysztof-card__name-row h2, h2.mb-0 { margin-bottom: 0; }
  .krzysztof-card__li {
    color: #0a66c2;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .krzysztof-card__li:hover { opacity: 0.75; }
  .krzysztof-card__li svg { width: 20px; height: 20px; display: block; }
  .krzysztof-card__role {
    font-size: 13px;
    color: var(--fg3);
    margin: 0 0 12px;
    font-weight: var(--fw-light);
  }
  .krzysztof-card__desc {
    color: var(--fg2);
    margin: 0 0 20px;
    font-weight: var(--fw-light);
  }
  @media (max-width: 600px) {
    .krzysztof-card { flex-direction: column; text-align: center; }
    .krzysztof-card__name-row { justify-content: center; }
  }

  /* ============== section card ============== */
  .card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-xl);
    padding: 48px 64px;
    box-shadow: var(--elevation-1);
    margin-bottom: 24px;
  }
  .card h2 {
    font-family: var(--font-display);
    font-size: var(--fs-title-large);
    line-height: 1.2;
    letter-spacing: var(--ls-title-large);
    font-weight: var(--fw-medium);
    margin-bottom: 12px;
    color: var(--fg1);
  }
  .card h3 {
    font-family: var(--font-display);
    font-size: var(--fs-title-medium);
    letter-spacing: var(--ls-title-medium);
    font-weight: var(--fw-medium);
    margin: 24px 0 8px;
    color: var(--fg1);
  }
  .card p { color: var(--fg1); margin-bottom: 12px; font-weight: var(--fw-light); }

  /* ============== quiz ============== */
  .quiz {
    display: none;
  }
  .quiz.active { display: block; }

  .quiz__progress {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .quiz__progress-bar {
    flex: 1;
    height: 4px;
    background: var(--surface-variant);
    border-radius: 2px;
    overflow: hidden;
  }
  .quiz__progress-fill {
    height: 100%;
    background: var(--primary);
    width: 0%;
    transition: width 300ms var(--motion-standard);
  }
  .quiz__progress-label {
    font-size: 12px;
    color: var(--fg2);
    font-weight: 500;
    letter-spacing: 0.3px;
  }

  .question__dim {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--fs-label-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-kicker);
    color: var(--primary);
    font-weight: var(--fw-bold);
    padding: 4px 10px;
    border: 1px solid var(--primary);
    border-radius: var(--radius-pill);
    margin-bottom: 16px;
  }
  .question__text {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: var(--ls-headline-small);
    font-weight: var(--fw-medium);
    margin-bottom: 32px;
    color: var(--fg1);
  }

  .answers {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .answer {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 20px;
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    background: var(--surface);
    cursor: pointer;
    transition: border-color var(--motion-short) var(--motion-standard),
                background var(--motion-short) var(--motion-standard);
    text-align: left;
    font-family: var(--font-sans);
    font-size: var(--fs-body-medium);
    font-weight: var(--fw-light);
    color: var(--fg1);
    width: 100%;
  }
  @media (hover: hover) {
    .answer:hover {
      border-color: var(--primary);
      background: var(--surface-pink-softest);
    }
    .answer:hover .answer__num {
      background: var(--primary);
      color: var(--on-primary);
    }
  }
  .answer.selected {
    border-color: var(--primary);
    background: var(--surface-pink-softest);
  }
  .answer__num {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-sm);
    background: var(--surface-container);
    color: var(--fg2);
    font-size: 12px;
    font-weight: var(--fw-bold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .answer.selected .answer__num {
    background: var(--primary);
    color: var(--on-primary);
  }
  .answer__text { flex: 1; line-height: 1.45; }

  .quiz__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--outline-variant);
  }
  .quiz__hint { font-size: 12px; color: var(--fg3); }

  /* ARR input */
  .arr-input {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .arr-input__row {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .arr-input input[type=range] {
    flex: 1;
    accent-color: var(--primary);
  }
  .arr-input__display {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-headline-medium);
    color: var(--primary);
    min-width: 140px;
    line-height: 1;
  }
  .arr-input__hint {
    font-size: var(--fs-body-small);
    color: var(--fg2);
  }

  /* ============== result ============== */
  .result { display: none; }
  .result.active { display: block; }

  .result__hero {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-xl);
    padding: 56px 64px 48px;
    box-shadow: var(--elevation-2);
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }
  .result__hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--primary);
  }
  .result__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .result__code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--surface-container);
    border: 1px solid var(--outline-variant);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.12em;
    color: var(--fg1);
  }
  .result__class {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--fs-label-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-kicker);
    color: var(--primary);
    font-weight: var(--fw-bold);
  }
  .result__name {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--ls-headline-medium);
    font-weight: var(--fw-medium);
    margin-bottom: 14px;
    color: var(--fg1);
  }
  .result__name em {
    color: var(--primary);
    font-style: normal;
    font-weight: var(--fw-medium);
  }
  .result__profile {
    font-size: var(--fs-body-large);
    color: var(--fg2);
    font-weight: var(--fw-light);
    line-height: 1.55;
    max-width: 65ch;
    margin-bottom: 32px;
  }

  .leakage {
    background: var(--surface-pink-softest);
    border: 1px solid var(--outline-variant);
    border-left: 3px solid var(--primary);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    margin: 32px 0;
  }
  .leakage__lbl {
    font-family: var(--font-sans);
    font-size: var(--fs-label-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-kicker);
    color: var(--primary);
    font-weight: var(--fw-bold);
    margin-bottom: 10px;
  }
  .leakage__num {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-headline-medium);
    color: var(--fg1);
    line-height: 1;
    margin-bottom: 10px;
  }
  .leakage__sub {
    font-size: var(--fs-body-small);
    color: var(--fg2);
  }

  .dim-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 32px 0;
  }
  .dim {
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    box-shadow: var(--elevation-1);
  }
  .dim__lbl {
    font-family: var(--font-sans);
    font-size: var(--fs-label-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-kicker);
    color: var(--fg2);
    font-weight: var(--fw-bold);
    margin-bottom: 10px;
  }
  .dim__score {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    font-size: var(--fs-label-medium);
    font-weight: var(--fw-bold);
    letter-spacing: 0.4px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .dim__score.l { background: var(--error-container); color: var(--on-error-container); }
  .dim__score.m { background: var(--surface-pink-softest); color: var(--primary); border: 1px solid var(--primary); }
  .dim__score.h { background: var(--tertiary); color: var(--on-tertiary); }
  .dim__desc { font-size: var(--fs-body-small); color: var(--fg2); line-height: 1.55; font-weight: var(--fw-light); }

  .moves {
    list-style: none;
    padding: 0;
    margin: 16px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .moves li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--primary);
  }
  .moves__num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-pill);
    background: var(--primary);
    color: var(--on-primary);
    font-size: 12px;
    font-weight: var(--fw-bold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .moves__text { font-size: var(--fs-body-medium); line-height: 1.55; font-weight: var(--fw-light); }

  .quote {
    border-left: 3px solid var(--primary);
    padding: 16px 0 16px 24px;
    margin: 32px 0;
    color: var(--fg1);
    font-family: var(--font-display);
    font-size: var(--fs-body-large);
    font-weight: var(--fw-light);
    font-style: italic;
    line-height: 1.55;
    letter-spacing: -0.005em;
  }
  .quote__author {
    font-family: var(--font-sans);
    font-style: normal;
    margin-top: 14px;
    font-size: var(--fs-body-small);
    color: var(--fg2);
    letter-spacing: 0;
  }
  .quote__author strong { color: var(--fg1); font-weight: var(--fw-medium); }

  /* ============== result gate modal ============== */
  .rg-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(10, 4, 14, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .rg-backdrop.active {
    display: flex;
  }
  .rg-modal {
    background: #fff;
    border-radius: 20px;
    padding: 40px 36px;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  }
  .rg-modal__lock {
    width: 56px;
    height: 56px;
    background: #fde8ef;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .rg-modal__lock svg { width: 26px; height: 26px; stroke: var(--primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .rg-modal h2 { font-size: 22px; font-weight: var(--fw-bold); color: var(--fg1); margin: 0 0 8px; }
  .rg-modal__sub { font-size: 15px; color: var(--fg2); margin: 0 0 24px; font-weight: var(--fw-light); }
  .rg-modal__teaser { margin: 0 0 28px; }
  .rg-modal__teaser-label { font-size: 12px; color: var(--fg3); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px; }
  .rg-modal__code { font-size: 40px; font-weight: var(--fw-bold); color: var(--fg1); letter-spacing: 0.05em; margin: 0 0 4px; }
  .rg-modal__name { font-size: 16px; font-weight: var(--fw-bold); color: var(--fg1); margin: 0 0 4px; }
  .rg-modal__desc { font-size: 14px; color: var(--fg2); margin: 0; font-weight: var(--fw-light); }
  .rg-modal__form { display: flex; flex-direction: column; gap: 10px; }
  .rg-modal__form input {
    padding: 14px 18px;
    border-radius: var(--radius-md);
    border: 1px solid var(--outline-variant);
    background: var(--surface-variant);
    color: var(--fg1);
    font-family: var(--font-sans);
    font-size: var(--fs-body-medium);
    font-weight: var(--fw-light);
    width: 100%;
    box-sizing: border-box;
    text-align: left;
  }
  .rg-modal__form input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 2px rgba(255,0,94,0.2); }
  .rg-modal__form input::placeholder { color: var(--fg3); }
  .rg-modal__form .btn { width: 100%; justify-content: center; }
  .rg-modal__fine { font-size: 12px; color: var(--fg3); margin: 8px 0 0; }
  .rg-modal__error { font-size: 12px; color: #c0002a; margin: 0; overflow: hidden; max-height: 0; transition: max-height 0.15s ease; }
  .rg-modal__error:not(:empty) { max-height: 40px; }

  /* ============== gate ============== */
  /* Aubergine register - mirrors the report-cover dark theme */
  .gate {
    position: relative;
    background: var(--inverse-surface);
    color: var(--inverse-on-surface);
    border-radius: var(--radius-xl);
    padding: 48px 56px;
    margin-bottom: 24px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .gate__plane {
    position: absolute;
    top: 50%;
    right: -40px;
    transform: translateY(-50%);
    width: 220px;
    height: 220px;
    pointer-events: none;
    opacity: 0.5;
  }
  .gate__plane svg { width: 100%; height: 100%; display: block; }
  .gate__inner { position: relative; z-index: 1; max-width: 60ch; }
  .gate h2 {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: var(--ls-headline-small);
    font-weight: var(--fw-medium);
    margin-bottom: 10px;
    color: var(--inverse-on-surface);
  }
  .gate p { color: var(--inverse-on-surface); opacity: 0.78; margin-bottom: 24px; font-weight: var(--fw-light); }
  .gate__form {
    display: flex;
    gap: 8px;
  }
  .gate__form input {
    flex: 1;
    padding: 14px 18px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.15);
    background: #fff;
    color: var(--fg1);
    font-family: var(--font-sans);
    font-size: var(--fs-body-medium);
    font-weight: var(--fw-light);
  }
  .gate__form input::placeholder { color: #888; }
  .gate__form input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(255, 0, 94, 0.25);
  }
  .gate__error {
    font-size: 12px;
    color: #ff6b8a;
    margin: 4px 0 0;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.15s ease;
  }
  .gate__error:not(:empty) { max-height: 40px; }

  /* ============== archetype gallery ============== */
  .archetypes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-top: 16px;
  }
  .arch-card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    padding: 22px;
    cursor: pointer;
    transition: border-color var(--motion-short) var(--motion-standard),
                transform var(--motion-short) var(--motion-standard),
                box-shadow var(--motion-short) var(--motion-standard);
    box-shadow: var(--elevation-1);
  }
  .arch-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--elevation-2);
  }
  .arch-card.you {
    border-color: var(--primary);
    background: var(--surface-pink-softest);
  }
  .arch-card__code {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg2);
    letter-spacing: 0.18em;
    margin-bottom: 6px;
  }
  .arch-card__name {
    font-family: var(--font-display);
    font-size: var(--fs-title-medium);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-title-medium);
    margin-bottom: 6px;
    color: var(--fg1);
  }
  .arch-card__leak {
    font-size: var(--fs-body-small);
    color: var(--fg2);
  }
  .arch-card__leak strong { color: var(--primary); font-weight: var(--fw-bold); }

  /* ============== announcement bar / header / footer ============== */
  .announce {
    background: var(--primary);
    color: var(--on-primary);
    text-align: center;
    padding: 10px 24px;
    font-size: var(--fs-body-small);
    font-weight: var(--fw-medium);
    letter-spacing: 0.2px;
  }
  .announce a {
    color: var(--on-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--outline-variant);
    padding: 16px 24px;
  }
  .topbar__inner {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .topbar__brand {
    display: flex;
    align-items: center;
  }
  .topbar__right {
    font-family: var(--font-sans);
    font-size: var(--fs-body-small);
    color: var(--fg2);
    letter-spacing: 0.2px;
  }

  .meta-footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--outline-variant);
    font-size: var(--fs-body-small);
    color: var(--fg3);
    text-align: center;
    line-height: 1.6;
    font-weight: var(--fw-light);
  }
  .meta-footer strong { color: var(--fg2); font-weight: var(--fw-medium); }

  /* responsive */
  @media (max-width: 720px) {
    .wrap { padding: 24px 16px 64px; }
    .hero { padding: 32px 24px; }
    .hero__plane { width: 180px; height: 180px; right: -50px; top: -30px; opacity: 0.5; }
    .card { padding: 32px 24px; }
    .result__hero { padding: 36px 24px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--outline-variant); }
    .dim-grid { grid-template-columns: 1fr; }
    .gate { padding: 36px 24px; }
    .gate__form { flex-direction: column; }
    .gate__form input { width: 100%; box-sizing: border-box; }
    .gate__form .btn { width: 100%; justify-content: center; }
    .gate__plane { display: none; }
    .question__text { font-size: 22px; }
    .result__name { font-size: 30px; }
    .leakage__num { font-size: 32px; }
    .topbar__right { display: none; }
    .hero__ctas { flex-direction: column; }
    .hero__ctas .btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 480px) {
    .rg-backdrop { padding: 12px; }
    .rg-modal { padding: 28px 20px; border-radius: 16px; }
    .rg-modal__code { font-size: 32px; }
    .stat__num { font-size: 24px; }
    .hero__plane { display: none; }
  }

  @media (max-width: 991px) {
    .quiz__hint { display: none; }
    .quiz__nav { justify-content: space-between; }
  }

  /* ============== report preview / sneak peek ============== */
  .preview-section {
    margin-top: 48px;
    margin-bottom: 24px;
  }
  .preview-section__header {
    text-align: center;
    margin-bottom: 24px;
    padding: 0 8px;
  }
  .preview-section__header h2 {
    font-family: var(--font-display);
    font-size: var(--fs-title-large);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-title-large);
    color: var(--fg1);
    margin: 8px 0 10px;
  }
  .preview-section__header p {
    font-size: var(--fs-body-medium);
    color: var(--fg2);
    font-weight: var(--fw-light);
    max-width: 56ch;
    margin: 0 auto;
    line-height: 1.6;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  .preview-card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-xl);
    padding: 32px 36px;
    box-shadow: var(--elevation-1);
  }
  .preview-card--wide {
    grid-column: 1 / -1;
  }
  .preview-card__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-kicker);
    color: var(--primary);
    margin-bottom: 8px;
  }
  .preview-card h3 {
    font-family: var(--font-display);
    font-size: var(--fs-title-medium);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-title-medium);
    color: var(--fg1);
    margin-bottom: 6px;
  }
  .preview-card__sub {
    font-size: var(--fs-body-small);
    color: var(--fg2);
    font-weight: var(--fw-light);
    margin-bottom: 28px;
    line-height: 1.5;
  }

  /* Distribution bars */
  .distrib-rows { display: flex; flex-direction: column; gap: 14px; }
  .distrib-row { display: flex; flex-direction: column; gap: 5px; }
  .distrib-row__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .distrib-row__name {
    font-size: var(--fs-label-medium);
    font-weight: var(--fw-medium);
    color: var(--fg1);
  }
  .distrib-row__name em {
    font-style: normal;
    font-size: 11px;
    color: var(--fg2);
    font-weight: var(--fw-light);
    margin-left: 6px;
  }
  .distrib-row__pct {
    font-family: var(--font-display);
    font-size: var(--fs-label-medium);
    font-weight: var(--fw-bold);
    color: var(--fg2);
  }
  .distrib-row--highlight .distrib-row__pct { color: var(--primary); }
  .distrib-track {
    height: 8px;
    background: var(--surface-variant);
    border-radius: 4px;
    overflow: hidden;
  }
  .distrib-fill {
    height: 100%;
    background: var(--surface-container);
    border-radius: 4px;
    transition: width 600ms cubic-bezier(.4,0,.2,1);
  }
  .distrib-row--highlight .distrib-fill { background: var(--primary); }
  .distrib-note {
    margin-top: 18px;
    font-size: 12px;
    color: var(--fg3);
    border-top: 1px solid var(--outline-variant);
    padding-top: 14px;
  }

  /* Leakage calculator */
  .arr-picker {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .arr-pill {
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--outline-variant);
    background: var(--surface);
    font-family: var(--font-sans);
    font-size: var(--fs-body-small);
    font-weight: var(--fw-medium);
    color: var(--fg2);
    cursor: pointer;
    transition: border-color var(--motion-short) var(--motion-standard),
                background var(--motion-short) var(--motion-standard),
                color var(--motion-short) var(--motion-standard);
  }
  .arr-pill.active {
    border-color: var(--primary);
    background: var(--surface-pink-softest);
    color: var(--primary);
  }
  .leakage-rows { display: flex; flex-direction: column; gap: 12px; }
  .leakage-row { display: flex; flex-direction: column; gap: 4px; }
  .leakage-row__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .leakage-row__label {
    font-size: var(--fs-label-medium);
    font-weight: var(--fw-medium);
    color: var(--fg1);
  }
  .leakage-row__label em {
    font-style: normal;
    font-size: 11px;
    color: var(--fg2);
    font-weight: var(--fw-light);
    margin-left: 4px;
  }
  .leakage-row__amount {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: var(--fw-bold);
    color: var(--fg1);
    white-space: nowrap;
  }
  .leakage-row--highlight .leakage-row__amount { color: var(--primary); }
  .leakage-track {
    height: 6px;
    background: var(--surface-variant);
    border-radius: 3px;
    overflow: hidden;
  }
  .leakage-fill {
    height: 100%;
    background: var(--surface-container);
    border-radius: 3px;
    transition: width 500ms cubic-bezier(.4,0,.2,1);
  }
  .leakage-row--highlight .leakage-fill { background: var(--primary); }
  .leakage-note {
    margin-top: 18px;
    font-size: 12px;
    color: var(--fg3);
    border-top: 1px solid var(--outline-variant);
    padding-top: 14px;
  }

  /* Gap comparison */
  .gap-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }
  .gap-item {
    background: var(--surface-container);
    border-radius: var(--radius-lg);
    padding: 20px 16px;
    text-align: center;
    border: 1px solid var(--outline-variant);
  }
  .gap-item--alert {
    background: var(--error-container);
    border-color: transparent;
  }
  .gap-item--good {
    background: var(--tertiary);
    border-color: transparent;
  }
  .gap-item__score {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .gap-item--alert .gap-item__score { color: var(--on-error-container); }
  .gap-item--good .gap-item__score { color: var(--on-tertiary); }
  .gap-item__score span { font-size: 16px; font-weight: var(--fw-medium); }
  .gap-item__label {
    font-size: 11px;
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: 0.4px;
    line-height: 1.4;
  }
  .gap-item--alert .gap-item__label { color: var(--on-error-container); opacity: 0.8; }
  .gap-item--good .gap-item__label { color: var(--on-tertiary); opacity: 0.85; }
  .gap-vs {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: var(--fw-bold);
    color: var(--fg3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .gap-finding {
    background: var(--surface-pink-softest);
    border-left: 3px solid var(--primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 14px 18px;
    font-size: var(--fs-body-small);
    color: var(--fg1);
    font-weight: var(--fw-light);
    line-height: 1.6;
    margin-top: 20px;
  }
  .gap-finding strong { color: var(--fg1); font-weight: var(--fw-medium); }

  /* preview CTA */
  .preview-cta {
    text-align: center;
    padding: 32px 24px;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-xl);
    box-shadow: var(--elevation-1);
  }
  .preview-cta p {
    font-size: var(--fs-body-medium);
    color: var(--fg2);
    font-weight: var(--fw-light);
    margin-bottom: 20px;
  }
  .preview-cta p strong { color: var(--fg1); font-weight: var(--fw-medium); }

  @media (max-width: 720px) {
    .preview-grid { grid-template-columns: 1fr; }
    .preview-card { padding: 24px 20px; }
    .gap-grid { grid-template-columns: 1fr; gap: 8px; }
    .gap-vs { display: none; }
    .arr-picker { gap: 6px; }
    .arr-pill { padding: 5px 11px; font-size: 12px; }
  }

  /* fade transitions */
  .stage { animation: fadeIn 300ms var(--motion-standard); }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
