/* =========================================================
   LEAKAGE CALCULATOR
   ========================================================= */
const LEAKAGE_CLASSES = [
  { label: 'Class 1', name: 'Improvisers',      lo: 0.17, hi: 0.25, highlight: false },
  { label: 'Class 2', name: 'Tool Collectors',  lo: 0.10, hi: 0.18, highlight: true  },
  { label: 'Class 3', name: 'Operators',        lo: 0.08, hi: 0.14, highlight: false },
